// Prisma reads this file to generate the type-safe client and migration SQL.
// Docs: https://pris.ly/d/prisma-schema

// ============================================================
// GENERATOR
// Tells Prisma to generate a TypeScript client.
// Output goes to src/generated/prisma (gitignored — regenerated on each migration).
// ============================================================

generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// These map directly to PostgreSQL ENUM types.
// ============================================================

enum UserRole {
  admin
  customer
}

enum UserStatus {
  pending  // registered, email not yet verified
  active   // verified, full access
  deleted  // soft deleted — never hard delete to preserve order history
}

enum OrderStatus {
  pending    // order created, payment not yet received
  paid       // payment captured, triggers email delivery
  fulfilled  // download link emailed to customer
  refunded   // customer refunded within 30-day window
}

enum PaymentStatus {
  pending
  captured
  failed
  refunded
}

enum NotificationType {
  order_fulfilled  // payment captured + download link sent
  payment_failed   // payment capture failed
  order_refunded   // refund processed
}

// ============================================================
// USERS
// Central table. Never hard deleted — use status = deleted instead
// to preserve foreign key integrity with orders.
// ============================================================

model User {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String     @unique
  passwordHash String     @map("password_hash")
  firstName    String     @map("first_name")
  lastName     String     @map("last_name")
  role                        UserRole   @default(customer)
  status                      UserStatus @default(pending)
  verificationToken           String?    @unique @map("verification_token")
  verificationTokenExpiresAt  DateTime?  @map("verification_token_expires_at") @db.Timestamptz()
  createdAt                   DateTime   @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt                   DateTime   @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  cart                 Cart?
  bundles              Bundle[]
  products             Product[]
  orders               Order[]
  orderStatusHistories OrderStatusHistory[]
  notifications        Notification[]

  @@map("users")
}

// ============================================================
// BUNDLES
// A bundle groups assets together with an optional discount.
// The purchasable bundle itself is a Product row with is_bundle = true.
// ============================================================

model Bundle {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String   @unique
  slug            String   @unique
  description     String?
  // Whole number percentage between 0 and 100. Null means no discount.
  discountPercent Int?     @map("discount_percent")
  isActive        Boolean  @default(true) @map("is_active")
  createdBy       String?  @map("created_by") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  creator  User?     @relation(fields: [createdBy], references: [id])
  products Product[]

  @@map("bundles")
}

// ============================================================
// PRODUCTS
// Represents a single digital art asset or a purchasable bundle.
// is_bundle = true means this row IS the bundle product (excluded from asset listings).
// bundle_id links an asset to the bundle it belongs to.
// ============================================================

model Product {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String   @unique
  slug            String   @unique
  description     String?
  price           Decimal  @db.Decimal(12, 2)
  // Individual asset discount. Null means no discount.
  discountPercent Int?     @map("discount_percent")
  // preview_key — S3 object key for the public watermarked preview
  previewKey      String   @unique @map("preview_key")
  // asset_key — S3 object key for the private original asset
  assetKey        String   @unique @map("asset_key")
  bundleId        String?  @map("bundle_id") @db.Uuid
  // True only for the row that represents the purchasable bundle product.
  isBundle        Boolean  @default(false) @map("is_bundle")
  isActive        Boolean  @default(true) @map("is_active")
  createdBy       String?  @map("created_by") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  bundle       Bundle?      @relation(fields: [bundleId], references: [id])
  creator      User?        @relation(fields: [createdBy], references: [id])
  tags         ProductTag[]
  cartItems    CartItem[]
  orderItems   OrderItem[]

  @@index([bundleId])
  @@index([isActive])
  @@map("products")
}

// ============================================================
// TAGS
// Used for discovery and filtering since there are no categories.
// ============================================================

model Tag {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  products ProductTag[]

  @@map("tags")
}

// ============================================================
// PRODUCT TAGS
// Join table between products and tags.
// No updated_at — rows are only ever inserted or deleted.
// ============================================================

model ProductTag {
  productId String   @map("product_id") @db.Uuid
  tagId     String   @map("tag_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
  @@map("product_tags")
}

// ============================================================
// CARTS
// One cart per user (enforced by @unique on userId).
// ============================================================

model Cart {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@map("carts")
}

// ============================================================
// CART ITEMS
// No quantity — digital assets are not depleted.
// No updated_at — rows are only ever inserted or deleted.
// ============================================================

model CartItem {
  cartId    String   @map("cart_id") @db.Uuid
  productId String   @map("product_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([cartId, productId])
  @@map("cart_items")
}

// ============================================================
// ORDERS
// No quantity on items — digital assets are not depleted.
// Users can purchase the same asset multiple times (no restriction).
// ============================================================

model Order {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String      @map("user_id") @db.Uuid
  status      OrderStatus @default(pending)
  totalAmount Decimal     @map("total_amount") @db.Decimal(12, 2)
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime    @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  user          User                 @relation(fields: [userId], references: [id])
  items         OrderItem[]
  statusHistory OrderStatusHistory[]
  payment       Payment?

  @@index([userId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("orders")
}

// ============================================================
// ORDER ITEMS
// Stores unit_price at time of purchase so price changes don't
// affect historical orders.
// ============================================================

model OrderItem {
  orderId   String  @map("order_id") @db.Uuid
  productId String  @map("product_id") @db.Uuid
  unitPrice Decimal @map("unit_price") @db.Decimal(12, 2)

  // Relations
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@id([orderId, productId])
  @@index([orderId])
  @@map("order_items")
}

// ============================================================
// ORDER STATUS HISTORY
// Immutable audit trail — one row per status change.
// Single source of truth for when fulfillment occurred
// (used to enforce the 30-day refund window).
// ============================================================

model OrderStatusHistory {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId   String      @map("order_id") @db.Uuid
  status    OrderStatus
  note      String?
  changedBy String?     @map("changed_by") @db.Uuid
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  changer User? @relation(fields: [changedBy], references: [id])

  @@index([orderId])
  @@map("order_status_history")
}

// ============================================================
// PAYMENTS
// One payment per order (enforced by @unique on orderId).
// provider = 'stripe' — using Stripe test mode.
// provider_reference = Stripe transaction ID returned after capture.
// metadata = raw Stripe response payload stored as JSON.
// ============================================================

model Payment {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId           String        @unique @map("order_id") @db.Uuid
  amount            Decimal       @db.Decimal(12, 2)
  status            PaymentStatus @default(pending)
  provider          String        @default("stripe")
  providerReference String?       @map("provider_reference")
  metadata          Json?
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime      @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// ============================================================
// NOTIFICATIONS
// Backend-owned — types are seeded and never admin-managed.
// is_read allows efficient querying of unread notifications per user.
// metadata stores flexible payload e.g. { order_id, product_id }.
// ============================================================

model Notification {
  id        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false) @map("is_read")
  metadata  Json?
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt(sort: Desc)])
  @@map("notifications")
}
